#!/bin/bash

#########################################
# Utility Functions

# Create a new git repo with one README commit and CD into it
function gitnr() { mkdir -p "$1" && cd "$1" && git init && touch README && git add README && git commit -m "First commit"; }

# Do a Matrix movie effect of falling characters
function matrix1() {
echo -e "\e[1;40m" ; clear ; while :; do echo $LINES $COLUMNS $(( $RANDOM % $COLUMNS)) $(( $RANDOM % 72 )) ;sleep 0.05; done|gawk '{ letters="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*()"; c=$4; letter=substr(letters,c,1);a[$3]=0;for (x in a) {o=a[x];a[x]=a[x]+1; printf "\033[%s;%sH\033[2;32m%s",o,x,letter; printf "\033[%s;%sH\033[1;37m%s\033[0;0H",a[x],x,letter;if (a[x] >= $1) { a[x]=0; } }}'
}

function matrix2() {
echo -e "\e[1;40m" ; clear ; characters=$( jot -c 94 33 | tr -d '\n' ) ; while :; do echo $LINES $COLUMNS $(( $RANDOM % $COLUMNS)) $(( $RANDOM % 72 )) $characters ;sleep 0.05; done|gawk '{ letters=$5; c=$4; letter=substr(letters,c,1);a[$3]=0;for (x in a) {o=a[x];a[x]=a[x]+1; printf "\033[%s;%sH\033[2;32m%s",o,x,letter; printf "\033[%s;%sH\033[1;37m%s\033[0;0H",a[x],x,letter;if (a[x] >= $1) { a[x]=0; } }}'
}

function tmx() {
        tmux attach-session -t "$1" || tmux new-session -s "$1"
}

# Usage:
# pair_programming [session_name] [window_name]
function pair_programming() {
	if ! command -v tmux &> /dev/null; then
		echo "tmux is not installed. Please install tmux to continue."
		return 1
	fi

	SESSION_NAME="${1:-pair-session}"
	TMUX_CONFIG="${2:-}"
	SOCKET_PATH="/tmp/tmux_pair_socket"

	if [[ -n "$TMUX_CONFIG" && ! -f "$TMUX_CONFIG" ]]; then
		echo "Specified tmux config file '$TMUX_CONFIG' not found."
		return 1
	fi

	if [ ! -d "/tmp/tmux_pair_socket" ]; then
		mkdir -p "$SOCKET_PATH"
		chmod 777 "$SOCKET_PATH"
	fi

	TMUX_CMD="tmux"
	[[ -n "$TMUX_CONFIG" ]] && TMUX_CMD="tmux -f $TMUX_CONFIG"
	
	echo $TMUX_CMD

	$TMUX_CMD -S "$SOCKET_PATH/$SESSION_NAME" has-session -t "$SESSION_NAME" 2>/dev/null

	if [ $? != 0 ]; then
		echo "starting a new tmux session on a shared socket: $SESSION_NAME"
		$TMUX_CMD -S "$SOCKET_PATH/$SESSION_NAME" new-session -s "$SESSION_NAME" -d
		chmod 777 "$SOCKET_PATH/$SESSION_NAME"
	else
		echo "Attaching to existing tmux session on shared socket: $SESSION_NAME"

#		$TMUX_CMD -S "$SOCKET_PATH/$SESSION_NAME" set-option -t "$SESSION_NAME" -g mouse on
	# $TMUX_CMD -S "$SOCKET_PATH/$SESSION_NAME" set-option -t "$SESSION_NAME" -g synchronize-panes on
	fi

	$TMUX_CMD -S "$SOCKET_PATH/$SESSION_NAME" has-session -t "$(whoami)" 2>/dev/null
	if [ $? != 0 ]; then
		$TMUX_CMD -S "$SOCKET_PATH/$SESSION_NAME" new-session -s "$(whoami)" -t "$SESSION_NAME" -d
	fi


	$TMUX_CMD -S "$SOCKET_PATH/$SESSION_NAME" attach-session -t "$(whoami)"
}


# kill all instances of a process by name
function skill()
{
    pkill -9 --signal "-9" "$1" || sudo pkill -9 "$1"
}

function fixperms(){
    find . \( -name "*.sh" -or -type d \) -exec chmod 755 {} \; && find . -type f ! -name "*.sh" -exec chmod 644 {} \;
}
